# Supabase (used by web app, and by extension via build-time config)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# NOTE: The Chrome extension cannot read .env at runtime.
# Supabase URL + anon key for the extension are bundled at build time
# via apps/extension/src/lib/config.ts (see TODO in that file).
