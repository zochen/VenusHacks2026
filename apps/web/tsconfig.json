{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@quietspace/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@quietspace/shared-types/*": [
        "../../packages/shared-types/src/*"
      ],
      "@quietspace/shared-ui": [
        "../../packages/shared-ui/src/index.ts"
      ],
      "@quietspace/shared-ui/*": [
        "../../packages/shared-ui/src/*"
      ],
      "@quietspace/shared-lib": [
        "../../packages/shared-lib/src/index.ts"
      ],
      "@quietspace/shared-lib/*": [
        "../../packages/shared-lib/src/*"
      ],
      "@/*": [
        "./*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
